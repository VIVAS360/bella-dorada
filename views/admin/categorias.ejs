<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= bd_h(title) %> | Admin Bella Dorada</title>
  <link rel="stylesheet" href="/admin-assets/admin.css">
</head>

<body class="<%= active === 'categorias' ? 'admin-sidebar-collapsed' : '' %>">

  <div class="admin-sidebar-overlay" data-admin-menu-close></div>

  <aside class="admin-sidebar" data-admin-sidebar>
    <div class="admin-sidebar-head">
      <a class="admin-brand" href="/admin/dashboard">
        <span>BD</span>
        <strong>Bella Dorada</strong>
      </a>

      <button type="button" class="admin-sidebar-close" data-admin-menu-close aria-label="Cerrar menú">
        ×
      </button>
    </div>

    <nav>
      <a class="<%= active === 'dashboard' ? 'active' : '' %>" href="/admin/dashboard">Dashboard</a>
      <a class="<%= active === 'productos' ? 'active' : '' %>" href="/admin/productos">Ramos full</a>
      <a class="<%= active === 'productos_individuales' ? 'active' : '' %>" href="/admin/productos_individuales">Productos individuales</a>
      <a class="<%= active === 'presentaciones' ? 'active' : '' %>" href="/admin/presentaciones">Presentaciones ramos</a>
      <a class="<%= active === 'categorias' ? 'active' : '' %>" href="/admin/categorias">Categorías produtos</a>
      <a class="<%= active === 'ventas' ? 'active' : '' %>" href="/admin/ventas">Ventas</a>
      <a class="<%= active === 'pedidos' ? 'active' : '' %>" href="/admin/pedidos">Pedidos</a>
      <a class="<%= active === 'compras' ? 'active' : '' %>" href="/admin/compras">Compras</a>
      <a class="<%= active === 'usuarios' ? 'active' : '' %>" href="/admin/usuarios">Usuarios</a>
      <a class="<%= active === 'roles' ? 'active' : '' %>" href="/admin/roles">Roles</a>
      <a href="/index.html" target="_blank">Ver web</a>
    </nav>
  </aside>

  <main class="admin-main">
    <header class="admin-topbar">
      <div class="admin-topbar-left">
        <button type="button" class="admin-menu-toggle" data-admin-menu-toggle aria-label="Abrir menú">
          <span></span>
          <span></span>
          <span></span>
        </button>

        <div>
          <p>Panel administrativo</p>
          <h1><%= bd_h(title) %></h1>
        </div>
      </div>

      <div class="admin-user">
        <span><%= bd_h(user.nombre) %></span>
        <a href="/admin/logout">Salir</a>
      </div>
    </header>

    <% if (flash) { %>
      <div class="alert <%= bd_h(flash.type) %>"><%= bd_h(flash.message) %></div>
    <% } %>

    <section class="admin-card admin-toolbar-card">
      <div class="admin-card-header">
        <div>
          <h2>Categorías</h2>
          <p>Administra las categorías de ramos y de productos individuales.</p>
        </div>

        <button type="button" class="btn btn-primary" data-open-category-modal>
          + Crear categoría
        </button>
      </div>
    </section>

    <div class="bd-modal-overlay <%= editing ? 'is-open' : '' %>" data-category-modal aria-hidden="<%= editing ? 'false' : 'true' %>">
      <div class="bd-modal">
        <div class="bd-modal-header">
          <div>
            <p class="eyebrow">Catálogo Bella Dorada</p>
            <h2><%= editing ? 'Editar categoría' : 'Nueva categoría' %></h2>
          </div>

          <button type="button" class="bd-modal-close" data-close-category-modal data-cancel-url="<%= editing ? '/admin/categorias' : '' %>" aria-label="Cerrar modal">
            ×
          </button>
        </div>

        <form method="post" class="bd-modal-form">
          <input type="hidden" name="id_original" value="<%= bd_h(String(editing ? editing.id : '')) %>">

          <div class="form-grid three">
            <div class="form-field">
              <label>Identificador</label>
              <input name="id" value="<%= bd_h(editing ? editing.id : '') %>" placeholder="maquillaje-individual">
              <small class="field-help">
                Si lo deja vacío, se genera automáticamente con el nombre.
              </small>
            </div>

            <div class="form-field">
              <label>Nombre</label>
              <input name="nombre" value="<%= bd_h(editing ? editing.nombre : '') %>" placeholder="Maquillaje individual" required>
            </div>

            <div class="form-field">
              <label>Tipo de categoría</label>
              <select name="tipo_categoria" required>
                <option value="ramos" <%= (!editing || editing.tipo_categoria === 'ramos') ? 'selected' : '' %>>Ramos</option>
                <option value="individual" <%= (editing && editing.tipo_categoria === 'individual') ? 'selected' : '' %>>Productos individuales</option>
              </select>
            </div>

            <div class="form-field">
              <label>Orden</label>
              <input name="orden" type="number" min="1" value="<%= editing ? (editing.orden || 1) : 1 %>">
            </div>
          </div>

          <div class="form-checks" style="margin-top: 14px;">
            <label>
              <input type="checkbox" name="estado" <%= (!editing || editing.estado !== false) ? 'checked' : '' %>>
              Visible
            </label>
          </div>

          <div class="bd-modal-actions">
            <button class="btn btn-primary" type="submit">
              Guardar categoría
            </button>

            <button type="button" class="btn btn-soft" data-close-category-modal data-cancel-url="<%= editing ? '/admin/categorias' : '' %>">
              Cancelar
            </button>
          </div>
        </form>
      </div>
    </div>

    <section class="admin-card">
      <div class="admin-card-header">
        <h2>Listado de categorías</h2>
      </div>

      <div class="table-wrap table-wrap-categories">
        <table class="categories-table">
          <thead>
            <tr>
              <th>Orden</th>
              <th>Categoría</th>
              <th>Tipo</th>
              <th>Productos</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>

          <tbody>
            <% categorias.forEach(categoria => { %>
              <% 
                const idCategoria = String(categoria.id || '');
                const productosVinculados = bd_count_productos_categoria(productos, idCategoria);
                const visible = categoria.estado !== false;
              %>
              <tr>
                <td data-label="Orden">
                  <%= categoria.orden || 999 %>
                </td>

                <td data-label="Categoría" class="td-product">
                  <strong><%= bd_h(categoria.nombre || '') %></strong>
                  <small><%= bd_h(idCategoria) %></small>
                </td>

                <td data-label="Tipo">
                  <span class="status <%= (categoria.tipo_categoria === 'individual') ? 'warn' : 'ok' %>">
                    <%= bd_h(bd_tipo_categoria_label(categoria.tipo_categoria || 'ramos')) %>
                  </span>
                </td>

                <td data-label="Productos">
                  <span class="status <%= productosVinculados > 0 ? 'ok' : 'warn' %>">
                    <%= productosVinculados %>
                  </span>
                </td>

                <td data-label="Estado">
                  <span class="status <%= visible ? 'ok' : 'bad' %>">
                    <%= visible ? 'Visible' : 'Oculta' %>
                  </span>
                </td>

                <td data-label="Acciones" class="td-actions">
                  <a class="btn btn-soft" href="/admin/categorias?editar=<%= encodeURIComponent(idCategoria) %>">
                    Editar
                  </a>

                  <% if (visible) { %>
                    <a class="btn btn-danger" href="/admin/categorias/ocultar/<%= encodeURIComponent(idCategoria) %>" onclick="return confirm('¿Ocultar esta categoría? Los productos vinculados dejarán de mostrarse en la web.')">
                      Ocultar
                    </a>
                  <% } else { %>
                    <a class="btn btn-soft" href="/admin/categorias/activar/<%= encodeURIComponent(idCategoria) %>">
                      Activar
                    </a>
                  <% } %>

                  <% if (productosVinculados <= 0) { %>
                    <a class="btn btn-danger" href="/admin/categorias/eliminar/<%= encodeURIComponent(idCategoria) %>" onclick="return confirm('¿Eliminar definitivamente esta categoría?')">
                      Eliminar
                    </a>
                  <% } else { %>
                    <button type="button" class="btn btn-disabled" disabled title="No se puede eliminar porque tiene productos vinculados">
                      Eliminar
                    </button>
                  <% } %>
                </td>
              </tr>
            <% }); %>

            <% if (categorias.length === 0) { %>
              <tr>
                <td colspan="6">No hay categorías creadas todavía.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>

  </main>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const modal = document.querySelector('[data-category-modal]');
      const openButton = document.querySelector('[data-open-category-modal]');
      const closeButtons = document.querySelectorAll('[data-close-category-modal]');

      function openCategoryModal() {
        if (!modal) return;
        modal.classList.add('is-open');
        modal.setAttribute('aria-hidden', 'false');
        document.body.classList.add('bd-modal-open');
      }

      function closeCategoryModal(button) {
        const cancelUrl = button?.dataset?.cancelUrl || '';
        if (cancelUrl) {
          window.location.href = cancelUrl;
          return;
        }
        if (!modal) return;
        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('bd-modal-open');
      }

      if (modal && modal.classList.contains('is-open')) {
        document.body.classList.add('bd-modal-open');
      }

      if (openButton) {
        openButton.addEventListener('click', openCategoryModal);
      }

      closeButtons.forEach(function (button) {
        button.addEventListener('click', function () {
          closeCategoryModal(button);
        });
      });

      if (modal) {
        modal.addEventListener('click', function (event) {
          if (event.target === modal) {
            const closeButton = document.querySelector('[data-close-category-modal]');
            closeCategoryModal(closeButton);
          }
        });
      }

      document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape' && modal && modal.classList.contains('is-open')) {
          const closeButton = document.querySelector('[data-close-category-modal]');
          closeCategoryModal(closeButton);
        }
      });
    });
  </script>
</body>
</html>
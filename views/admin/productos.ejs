<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= bd_h(title) %> | Admin Bella Dorada</title>
  <link rel="stylesheet" href="/admin-assets/admin.css">
</head>

<body class="<%= active === 'productos' ? 'admin-sidebar-collapsed' : '' %>">

  <div class="admin-sidebar-overlay" data-admin-menu-close></div>

  <aside class="admin-sidebar" data-admin-sidebar>
    <div class="admin-sidebar-head">
      <a class="admin-brand" href="/admin/dashboard">
        <span>BD</span>
        <strong>Bella Dorada</strong>
      </a>

      <button type="button" class="admin-sidebar-close" data-admin-menu-close aria-label="Cerrar menú">
        ×
      </button>
    </div>

    <nav>
      <a class="<%= active === 'dashboard' ? 'active' : '' %>" href="/admin/dashboard">Dashboard</a>
      <a class="<%= active === 'productos' ? 'active' : '' %>" href="/admin/productos">Ramos full</a>
      <a class="<%= active === 'productos_individuales' ? 'active' : '' %>" href="/admin/productos_individuales">Productos individuales</a>
      <a class="<%= active === 'presentaciones' ? 'active' : '' %>" href="/admin/presentaciones">Presentaciones ramos</a>
      <a class="<%= active === 'categorias' ? 'active' : '' %>" href="/admin/categorias">Categorías produtos</a>
      <a class="<%= active === 'ventas' ? 'active' : '' %>" href="/admin/ventas">Ventas</a>
      <a class="<%= active === 'pedidos' ? 'active' : '' %>" href="/admin/pedidos">Pedidos</a>
      <a class="<%= active === 'compras' ? 'active' : '' %>" href="/admin/compras">Compras</a>
      <a class="<%= active === 'usuarios' ? 'active' : '' %>" href="/admin/usuarios">Usuarios</a>
      <a class="<%= active === 'roles' ? 'active' : '' %>" href="/admin/roles">Roles</a>
      <a href="/" target="_blank">Ver web</a>
    </nav>
  </aside>

  <main class="admin-main">
    <header class="admin-topbar">
      <div class="admin-topbar-left">
        <button type="button" class="admin-menu-toggle" data-admin-menu-toggle aria-label="Abrir menú">
          <span></span>
          <span></span>
          <span></span>
        </button>

        <div>
          <p>Panel administrativo</p>
          <h1><%= bd_h(title) %></h1>
        </div>
      </div>

      <div class="admin-user">
        <span><%= bd_h(user.nombre) %></span>
        <a href="/admin/logout">Salir</a>
      </div>
    </header>

    <% if (flash) { %>
      <div class="alert <%= bd_h(flash.type) %>"><%= bd_h(flash.message) %></div>
    <% } %>

    <section class="admin-card admin-toolbar-card">
      <div class="admin-card-header">
        <div>
          <h2>Ramos full</h2>
          <p>Ramos completos de maquillaje y regalos personalizados</p>
        </div>

        <button type="button" class="btn btn-primary" data-open-product-modal>
          + Crear nuevo
        </button>
      </div>
    </section>

    <div class="bd-modal-overlay <%= editing ? 'is-open' : '' %>" data-product-modal aria-hidden="<%= editing ? 'false' : 'true' %>">
      <div class="bd-modal">
        <div class="bd-modal-header">
          <div>
            <p class="eyebrow">Gestión de producto</p>
            <h2><%= editing ? 'Editar ramo full' : 'Nuevo ramo full' %></h2>
          </div>

          <button type="button" class="bd-modal-close" data-close-product-modal data-cancel-url="<%= editing ? '/admin/productos' : '' %>" aria-label="Cerrar modal">
            ×
          </button>
        </div>

        <form method="post" class="bd-modal-form" enctype="multipart/form-data">
          <input type="hidden" name="id" value="<%= bd_h(String(editing ? editing.id : '')) %>">

          <div class="form-grid three">
            <div class="form-field">
              <label>Código</label>
              <input name="codigo" value="<%= bd_h(editing ? editing.codigo : '') %>" required>
            </div>

            <div class="form-field">
              <label>Nombre</label>
              <input name="nombre" value="<%= bd_h(editing ? editing.nombre : '') %>" required>
            </div>

            <div class="form-field">
              <label>Categoría</label>
              <select name="categoria" required>
                <option value="">Seleccionar</option>
                <% categorias.forEach(cat => { %>
                  <option value="<%= bd_h(cat.id) %>" <%= (editing && editing.categoria === cat.id) ? 'selected' : '' %>>
                    <%= bd_h(cat.nombre) %>
                  </option>
                <% }); %>
              </select>
            </div>

            <div class="form-field">
              <label>Precio venta</label>
              <input name="precio" value="<%= bd_h(editing ? editing.precio : '') %>" placeholder="149900" required>
            </div>

            <div class="form-field">
              <label>Precio unidad / compra</label>
              <input name="coste" value="<%= bd_h(editing ? editing.coste : '') %>" placeholder="85000">
            </div>

            <div class="form-field">
              <label>Stock disponible</label>
              <input name="stock" type="number" min="0" value="<%= editing ? editing.stock : 0 %>">
            </div>

            <div class="form-field full">
              <label>Imagen del producto</label>

              <input type="hidden" name="imagen_actual" value="<%= bd_h(editing ? editing.imagen : '') %>">

              <% if (editing && editing.imagen) { %>
                <div class="image-preview-admin">
                  <img src="<%= bd_h('../' + editing.imagen) %>" alt="Imagen actual">
                  <div>
                    <strong>Imagen actual</strong>
                    <small><%= bd_h(editing.imagen) %></small>
                  </div>
                </div>
              <% } %>

              <input type="file" name="imagen_file" accept="image/*">

              <small class="field-help">
                Puede subir una imagen desde la galería del celular o desde la PC. Formatos permitidos: JPG, PNG, WEBP o GIF. Máximo 5MB.
              </small>

              <input name="imagen" value="" placeholder="O pega una URL externa opcional: https://...">
            </div>

            <div class="form-field full">
              <label>Descripción</label>
              <textarea name="descripcion"><%= bd_h(editing ? editing.descripcion : '') %></textarea>
            </div>

            <div class="form-field full">
              <label>Tags separados por coma</label>
              <input name="tags" value="<%= bd_h(editing ? editing.tags.join(', ') : '') %>" placeholder="maquillaje, belleza, regalo">
            </div>
          </div>

          <div class="form-checks" style="margin-top: 14px;">
            <label>
              <input type="checkbox" name="destacado" <%= (editing && editing.destacado) ? 'checked' : '' %>>
              Destacado
            </label>

            <label>
              <input type="checkbox" name="estado" <%= (!editing || editing.estado !== false) ? 'checked' : '' %>>
              Visible
            </label>
          </div>

          <div class="bd-modal-actions">
            <button class="btn btn-primary" type="submit">
              Guardar ramo full
            </button>

            <button type="button" class="btn btn-soft" data-close-product-modal data-cancel-url="<%= editing ? '/admin/productos' : '' %>">
              Cancelar
            </button>
          </div>
        </form>
      </div>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const modal = document.querySelector('[data-product-modal]');
        const openButton = document.querySelector('[data-open-product-modal]');
        const closeButtons = document.querySelectorAll('[data-close-product-modal]');

        function openProductModal() {
          if (!modal) return;
          modal.classList.add('is-open');
          modal.setAttribute('aria-hidden', 'false');
          document.body.classList.add('bd-modal-open');
        }

        function closeProductModal(button) {
          const cancelUrl = button?.dataset?.cancelUrl || '';
          if (cancelUrl) {
            window.location.href = cancelUrl;
            return;
          }
          if (!modal) return;
          modal.classList.remove('is-open');
          modal.setAttribute('aria-hidden', 'true');
          document.body.classList.remove('bd-modal-open');
        }

        if (modal && modal.classList.contains('is-open')) {
          document.body.classList.add('bd-modal-open');
        }

        if (openButton) {
          openButton.addEventListener('click', openProductModal);
        }

        closeButtons.forEach(function (button) {
          button.addEventListener('click', function () {
            closeProductModal(button);
          });
        });

        if (modal) {
          modal.addEventListener('click', function (event) {
            if (event.target === modal) {
              const editing = modal.classList.contains('is-open') && document.querySelector('input[name="id"]')?.value;
              if (editing) {
                window.location.href = '/admin/productos';
                return;
              }
              closeProductModal();
            }
          });
        }

        document.addEventListener('keydown', function (event) {
          if (event.key === 'Escape' && modal && modal.classList.contains('is-open')) {
            const closeButton = document.querySelector('[data-close-product-modal]');
            closeProductModal(closeButton);
          }
        });
      });
    </script>

    <section class="admin-card">
      <div class="admin-card-header">
        <h2>Listado</h2>
      </div>

      <div class="table-wrap table-wrap-products">
        <table class="products-table">
          <thead>
            <tr>
              <th>Imagen</th>
              <th>Producto</th>
              <th>Categoría</th>
              <th>Venta</th>
              <th>Unidad</th>
              <th>Ganancia</th>
              <th>Total</th>
              <th>Stock</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>

          <tbody>
            <% productos.forEach(producto => { %>
              <% 
                const stock = producto.stock || 0;
                const precioVenta = bd_price_to_float(producto.precio || 0);
                const precioUnidad = bd_price_to_float(producto.coste || 0);
                const gananciaProducto = precioVenta - precioUnidad;
                const totalGanancias = gananciaProducto * stock;
                const estadoVisible = producto.estado !== false;
              %>
              <tr>
                <td data-label="Imagen">
                  <div class="product-thumb" style="background-image:url('<%= bd_h('../' + (producto.imagen || '')) %>')"></div>
                </td>

                <td data-label="Producto" class="td-product">
                  <strong><%= bd_h(producto.nombre || '') %></strong>
                  <small><%= bd_h(producto.codigo || '') %></small>
                </td>

                <td data-label="Categoría" class="td-category">
                  <%= bd_h(producto.categoria || '') %>
                </td>

                <td data-label="Precio venta" class="td-money">
                  <%= bd_h(bd_format_money(precioVenta)) %>
                </td>

                <td data-label="Precio unidad" class="td-money">
                  <%= bd_h(bd_format_money(precioUnidad)) %>
                </td>

                <td data-label="Ganancia producto" class="td-money">
                  <span class="status <%= gananciaProducto < 0 ? 'bad' : gananciaProducto <= 5000 ? 'warn' : 'ok' %>">
                    <%= bd_h(bd_format_money(gananciaProducto)) %>
                  </span>
                </td>

                <td data-label="Total ganancias" class="td-money">
                  <strong><%= bd_h(bd_format_money(totalGanancias)) %></strong>
                </td>

                <td data-label="Stock">
                  <span class="status <%= stock <= 3 ? 'warn' : 'ok' %>">
                    <%= stock %>
                  </span>
                </td>

                <td data-label="Estado">
                  <span class="status <%= estadoVisible ? 'ok' : 'bad' %>">
                    <%= estadoVisible ? 'Visible' : 'Oculto' %>
                  </span>
                </td>

                <td data-label="Acciones" class="td-actions">
                  <a class="btn btn-soft" href="/admin/productos?editar=<%= producto.id %>">
                    Editar
                  </a>

                  <a class="btn btn-danger" href="/admin/ramos/eliminar/<%= producto.id %>" onclick="return confirm('¿Desactivar este producto?')">
                    Ocultar
                  </a>
                </td>
              </tr>
            <% }); %>

            <% if (productos.length === 0) { %>
              <tr>
                <td colspan="10">
                  No hay productos creados todavía.
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>

  </main>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const body = document.body;
      const openButton = document.querySelector('[data-admin-menu-toggle]');
      const closeButtons = document.querySelectorAll('[data-admin-menu-close]');
      const sidebarLinks = document.querySelectorAll('.admin-sidebar nav a');

      function openMenu() {
        body.classList.add('admin-sidebar-open');
        body.classList.remove('admin-sidebar-collapsed');
      }

      function closeMenu() {
        body.classList.remove('admin-sidebar-open');
        body.classList.add('admin-sidebar-collapsed');
      }

      if (openButton) {
        openButton.addEventListener('click', function () {
          if (body.classList.contains('admin-sidebar-open')) {
            closeMenu();
          } else {
            openMenu();
          }
        });
      }

      closeButtons.forEach(function (button) {
        button.addEventListener('click', closeMenu);
      });

      sidebarLinks.forEach(function (link) {
        link.addEventListener('click', function () {
          if (window.innerWidth <= 980) {
            closeMenu();
          }
        });
      });

      document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
          closeMenu();
        }
      });
    });
  </script>
</body>
</html>